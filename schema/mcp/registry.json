{
  "version": "1.1",
  "updated": "2026-03-10",
  "context_window_budget": {
    "note": "Every enabled MCP adds tool count. 200k context becomes ~70k with too many tools. Keep under 10 enabled per session, under 80 active tools total.",
    "rule": "List all servers here. Mark default_enabled carefully. Disable per-project in harness config."
  },
  "servers": [
    {
      "name": "anima",
      "description": "Personal dev memory — identity, sessions, catalysts, synthesis",
      "tool_count": 7,
      "transport": "http",
      "port": 3098,
      "url": "http://localhost:3098/",
      "source": "~/anima/mcp-server/index.ts",
      "runtime": "deno",
      "daemon": "com.jcbbge.anima-mcp",
      "surreal_ns": "anima",
      "surreal_db": "memory",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp", "slate"],
      "disable_when": "never — identity layer, always needed",
      "tier": "T1"
    },
    {
      "name": "kotadb",
      "description": "Code index — symbols, dependencies, AST, embeddings",
      "tool_count": 12,
      "transport": "http",
      "port": 3099,
      "url": "http://localhost:3099/",
      "source": "~/kotadb/app/src/index.ts",
      "runtime": "bun",
      "daemon": "com.jcbbge.kotadb-app",
      "surreal_ns": "kotadb",
      "surreal_db": "index",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp", "slate"],
      "disable_when": "non-code sessions, writing, planning tasks",
      "tier": "T2",
      "triggers": ["search", "symbol", "semantic", "dependency", "ast", "code intelligence"]
    },
    {
      "name": "dev-brain",
      "description": "Dev intelligence — todos, threads, thoughts, workspace state",
      "tool_count": 18,
      "transport": "http",
      "port": 3097,
      "url": "http://localhost:3097/",
      "source": "~/dev-backbone/mcp-server/index.js",
      "runtime": "node",
      "daemon": "com.jcbbge.dev-brain-mcp",
      "surreal_ns": "dev",
      "surreal_db": "brain",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp", "slate"],
      "note": "HTTP MCP — shared across all harnesses",
      "tier": "T1"
    },
    {
      "name": "executor",
      "description": "Universal primitive runtime — execute TypeScript against unified tool catalog. Tools: execute, resume.",
      "tool_count": 2,
      "transport": "http",
      "port": 8000,
      "url": "http://127.0.0.1:8000/mcp",
      "source": "npm:executor",
      "runtime": "node",
      "daemon": "dev.brain.executor",
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp", "slate"],
      "disable_when": "never — universal runtime layer",
      "tier": "T1"
    },
    {
      "name": "subagent-mcp",
      "description": "Subagent delegation — invoke reviewer, test-writer, architect, debugger, sigil-distiller via model API",
      "tool_count": 2,
      "transport": "http",
      "port": 3096,
      "url": "http://localhost:3096/",
      "source": "~/dev-backbone/subagent-mcp/src/index.ts",
      "runtime": "bun",
      "daemon": "dev.brain.subagent-mcp",
      "status": "pending",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp", "slate"],
      "disable_when": "non-delegation sessions",
      "tier": "T2",
      "triggers": ["delegate", "review", "test", "architect", "debug"]
    }
  ],
  "project_scoped": [
    {
      "name": "HubSpotDev",
      "description": "HubSpot CRM integration — owners, contacts, deals, pipelines. Bento-only.",
      "transport": "stdio",
      "command": "hs",
      "args": ["mcp", "start", "--ai-agent", "claude"],
      "installed_via": "hs mcp setup --client claude",
      "account": "infinity (49701209)",
      "project": "/Users/jcbbge/Infinity/bento",
      "config_file": "/Users/jcbbge/Infinity/bento/.mcp.json",
      "status": "active",
      "default_enabled": false,
      "harnesses": ["claude-code"],
      "note": "Project-scoped — only available when working in the bento directory",
      "tier": "T3"
    }
  ],
  "port_allocation": {
    "8002": "SurrealDB — all namespaces (unified single instance)",
    "3099": "kotadb MCP HTTP",
    "3098": "anima MCP HTTP",
    "3097": "dev-brain MCP HTTP",
    "8000": "executor daemon — http://127.0.0.1:8000 — label: dev.brain.executor",
    "3096": "subagent-mcp MCP HTTP — http://127.0.0.1:3096 — label: dev.brain.subagent-mcp"
  }
