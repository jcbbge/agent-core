{
  "version": "1.1",
  "updated": "2026-03-07",
  "context_window_budget": {
    "note": "Every enabled MCP adds tool count. 200k context becomes ~70k with too many tools. Keep under 10 enabled per session, under 80 active tools total.",
    "rule": "List all servers here. Mark default_enabled carefully. Disable per-project in harness config."
  },
  "servers": [
    {
      "name": "anima",
      "description": "Personal dev memory — identity, sessions, catalysts, synthesis",
      "tool_count": 7,
      "transport": "http",
      "port": 3098,
      "url": "http://localhost:3098/",
      "source": "~/anima/mcp-server/index.ts",
      "runtime": "deno",
      "daemon": "com.jcbbge.anima-mcp",
      "surreal_ns": "anima",
      "surreal_db": "memory",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp"],
      "disable_when": "never — identity layer, always needed"
    },
    {
      "name": "kotadb",
      "description": "Code index — symbols, dependencies, AST, embeddings",
      "tool_count": 12,
      "transport": "http",
      "port": 3099,
      "url": "http://localhost:3099/",
      "source": "~/kotadb/app/src/index.ts",
      "runtime": "bun",
      "daemon": "com.jcbbge.kotadb-app",
      "surreal_ns": "kotadb",
      "surreal_db": "index",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp"],
      "disable_when": "non-code sessions, writing, planning tasks"
    },
    {
      "name": "dev-brain",
      "description": "Dev intelligence — todos, threads, thoughts, workspace state",
      "tool_count": 18,
      "transport": "http",
      "port": 3097,
      "url": "http://localhost:3097/",
      "source": "~/dev-backbone/mcp-server/index.js",
      "runtime": "node",
      "daemon": "com.jcbbge.dev-brain-mcp",
      "surreal_ns": "dev",
      "surreal_db": "brain",
      "surreal_port": 8002,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode", "omp"],
      "note": "HTTP MCP — shared across all harnesses"
    }
  ],
  "port_allocation": {
    "8002": "SurrealDB — all namespaces (unified single instance)",
    "3099": "kotadb MCP HTTP",
    "3098": "anima MCP HTTP",
    "3097": "dev-brain MCP HTTP",
    "3096": "next available"
  }
}
