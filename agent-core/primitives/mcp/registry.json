{
  "version": "1.1",
  "updated": "2026-03-07",
  "context_window_budget": {
    "note": "Every enabled MCP adds tool count. 200k context becomes ~70k with too many tools. Keep under 10 enabled per session, under 80 active tools total.",
    "rule": "List all servers here. Mark default_enabled carefully. Disable per-project in harness config."
  },
  "servers": [
    {
      "name": "anima",
      "description": "Personal dev memory — identity, sessions, catalysts, synthesis",
      "tool_count": 7,
      "transport": "http",
      "port": 3098,
      "url": "http://localhost:3098/",
      "source": "~/anima/mcp-server/index.ts",
      "runtime": "deno",
      "daemon": "com.jcbbge.anima-mcp",
      "surreal_ns": "anima",
      "surreal_db": "memory",
      "surreal_port": 8000,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code", "opencode"],
      "disable_when": "never — identity layer, always needed"
    },
    {
      "name": "kotadb",
      "description": "Code index — symbols, dependencies, AST, embeddings",
      "tool_count": 20,
      "transport": "http",
      "port": 3099,
      "url": "http://localhost:3099/mcp",
      "source": "~/kotadb/app/src/index.ts",
      "runtime": "bun",
      "daemon": "com.jcbbge.kotadb-app",
      "surreal_ns": "kotadb",
      "surreal_db": "index",
      "surreal_port": 7201,
      "status": "running",
      "default_enabled": true,
      "harnesses": ["claude-code"],
      "disable_when": "non-code sessions, writing, planning tasks"
    },
    {
      "name": "dev-brain",
      "description": "Dev intelligence — todos, threads, thoughts, workspace state",
      "tool_count": 15,
      "transport": "stdio",
      "port": null,
      "url": null,
      "source": "~/dev-backbone/mcp-server/index.js",
      "runtime": "node",
      "daemon": null,
      "surreal_ns": "dev",
      "surreal_db": "brain",
      "surreal_port": 8000,
      "status": "stdio-only",
      "needs": "http-conversion",
      "default_enabled": true,
      "harnesses": ["opencode"],
      "note": "Missing from claude-code. Needs HTTP conversion → port 3097."
    }
  ],
  "port_allocation": {
    "8000": "SurrealDB — brain/anima namespaces",
    "7201": "SurrealDB — kotadb code index",
    "3099": "kotadb MCP HTTP",
    "3098": "anima MCP HTTP",
    "3097": "dev-brain MCP HTTP (reserved, pending conversion)",
    "3096": "next available"
  }
}
